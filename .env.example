# EXEMPLO DE CONFIGURAÇÃO - COPIE ESTE ARQUIVO E RENOMEIE PARA .env

FB_HOST=localhost
FB_PORT=3050
# Mude este caminho para o seu banco principal de desenvolvimento:
FB_DATABASE=C:\caminho\para\seu\banco.fdb
FB_USER=SYSDBA
FB_PASSWORD=masterkey
FB_CHARSET=ISO8859_1

# Caso o Python não encontre o fbclient.dll automaticamente, informe o caminho absoluto dele abaixo:
# Ex: FB_CLIENT_PATH=C:\Program Files\Firebird\Firebird_4_0\fbclient.dll
FB_CLIENT_PATH=
